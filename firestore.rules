rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profiles: Users can read/write their own profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Listings & Roommate Posts: Everyone can see them, but only logged-in users can create/edit
    match /pg_listings/{listingId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    
    match /roommate_posts/{postId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    
    // Favorites: Users can manage their own favorites list
    match /favorites/{favoriteId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    
    // Chats & Messages: Only participants can access
    match /chats/{chatId} {
      allow read: if request.auth != null && (resource == null || request.auth.uid in resource.data.participants);
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if request.auth != null && 
          exists(/databases/$(database)/documents/chats/$(chatId)) &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if request.auth != null && 
          exists(/databases/$(database)/documents/chats/$(chatId)) &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
          request.resource.data.senderId == request.auth.uid;
      }
    }
  }
}
